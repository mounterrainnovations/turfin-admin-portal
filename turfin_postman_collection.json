  "item": [
    {
      "name": "Auth",
      "description": "Public authentication flows plus authenticated token revocation. Use these requests to create accounts, sign in, rotate JWTs, and sign out.",
      "item": [
        {
          "name": "Signup (End User)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.accessToken) {",
                  "    pm.collectionVariables.set(\"accessToken\", jsonData.data.accessToken);",
                  "    pm.collectionVariables.set(\"refreshToken\", jsonData.data.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"user@example.com\",\n    \"password\": \"password123\",\n    \"role\": \"end_user\",\n    \"firstName\": \"John\",\n    \"lastName\": \"Doe\",\n    \"displayName\": \"JohnD\",\n    \"gender\": \"male\",\n    \"dateOfBirth\": \"1995-05-15\",\n    \"city\": \"Kochi\",\n    \"state\": \"Kerala\",\n    \"preferredSports\": [\"football\", \"cricket\"]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "signup"]
            },
            "description": "Register a new end_user account. Creates auth identity + user profile in a single step."
          },
          "response": []
        },
        {
          "name": "Signup (Vendor Owner)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.accessToken) {",
                  "    pm.collectionVariables.set(\"accessToken\", jsonData.data.accessToken);",
                  "    pm.collectionVariables.set(\"refreshToken\", jsonData.data.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"vendor@example.com\",\n    \"password\": \"password123\",\n    \"role\": \"vendor_owner\",\n    \"vendorProfile\": {\n        \"businessName\": \"Acme Turf Fields\",\n        \"businessType\": \"company\",\n        \"ownerFullName\": \"John Vendor\",\n        \"address\": {\n            \"addressLineOne\": \"123 Stadium Drive\",\n            \"addressLineTwo\": \"Near Central Park\",\n            \"city\": \"Mumbai\",\n            \"state\": \"Maharashtra\",\n            \"pinCode\": \"400001\",\n            \"googleMapsLink\": \"https://maps.google.com/?q=123+Stadium+Drive\"\n        },\n        \"bankingDetails\": {\n            \"bankName\": \"HDFC Bank\",\n            \"accountHolderName\": \"John Vendor\",\n            \"accountNumber\": \"123456789012\",\n            \"ifsc\": \"HDFC0001234\",\n            \"upiId\": \"john@upi\"\n        }\n    }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "signup"]
            },
            "description": "Register a new vendor_owner account. Creates auth identity + vendor profile + empty KYC record in a single atomic transaction."
          },
          "response": []
        },
        {
          "name": "Signin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.accessToken) {",
                  "    pm.collectionVariables.set(\"accessToken\", jsonData.data.accessToken);",
                  "    pm.collectionVariables.set(\"refreshToken\", jsonData.data.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"user@example.com\",\n    \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/signin",
